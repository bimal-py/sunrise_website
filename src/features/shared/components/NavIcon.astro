---
type Props = {
  name: "home" | "services" | "gallery" | "videos" | "merchandise" | "about" | "contact";
  className?: string;
};

const { name, className } = Astro.props;
---

{
  name === "home" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 10.5 12 4l8 6.5" />
      <path d="M6.5 9.5V20h11V9.5" />
      <path d="M10 20v-5h4v5" />
    </svg>
  )
}
{
  name === "services" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="8" cy="8" r="2.5" />
      <circle cx="16" cy="8" r="2.5" />
      <path d="M3.5 18a4.5 4.5 0 0 1 4.5-4.5" />
      <path d="M20.5 18a4.5 4.5 0 0 0-4.5-4.5" />
      <path d="M8 13.5h8" />
    </svg>
  )
}
{
  name === "gallery" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3.5" y="6" width="17" height="12.5" rx="3" />
      <circle cx="12" cy="12.25" r="3.25" />
      <path d="M8 6l1.4-2h5.2L16 6" />
    </svg>
  )
}
{
  name === "videos" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3.5" y="6" width="13.5" height="12" rx="2.5" />
      <path d="m17 10 3.8-2.2a1 1 0 0 1 1.5.87v6.7a1 1 0 0 1-1.5.87L17 14" />
      <path d="m9.5 10 4 2.25-4 2.25Z" fill="currentColor" stroke="none" />
    </svg>
  )
}
{
  name === "merchandise" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 8h12l-1 11H7L6 8Z" />
      <path d="M9 8a3 3 0 0 1 6 0" />
      <path d="M9 11v.01" />
      <path d="M15 11v.01" />
    </svg>
  )
}
{
  name === "about" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="8" r="3" />
      <path d="M6.5 19a5.5 5.5 0 0 1 11 0" />
    </svg>
  )
}
{
  name === "contact" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6.8 4.8h2.8l1 3.2-1.9 1.7a14.6 14.6 0 0 0 5.6 5.6l1.7-1.9 3.2 1v2.8a1.6 1.6 0 0 1-1.7 1.6A15.9 15.9 0 0 1 5.2 6.5 1.6 1.6 0 0 1 6.8 4.8Z" />
    </svg>
  )
}
