<canvas class="starfield-canvas" aria-hidden="true"></canvas>

<script is:inline>
  const canvas = document.querySelector(".starfield-canvas");

  if (canvas instanceof HTMLCanvasElement) {
    const context = canvas.getContext("2d");

    if (context) {
      const stars = [];
      const baseCount = window.innerWidth < 768 ? 80 : 120;
      let width = window.innerWidth;
      let height = window.innerHeight;
      let centerX = width / 2;
      let centerY = height / 2;
      let orbitRotation = 0;

      const createStar = () => ({
        distance: Math.random() * Math.max(width, height) * 0.85,
        angle: Math.random() * Math.PI * 2,
        size: Math.random() * 1.1 + 0.22,
        speed: Math.random() * 0.00065 + 0.00008,
        drift: Math.random() * 0.05 + 0.01,
        alpha: Math.random() * 0.24 + 0.12,
        twinkle: Math.random() * Math.PI * 2
      });

      const resize = () => {
        const ratio = window.devicePixelRatio || 1;
        width = window.innerWidth;
        height = window.innerHeight;
        centerX = width / 2;
        centerY = height / 2;
        canvas.width = width * ratio;
        canvas.height = height * ratio;
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;
        context.setTransform(ratio, 0, 0, ratio, 0, 0);

        stars.length = 0;
        for (let index = 0; index < baseCount; index += 1) {
          stars.push(createStar());
        }
      };

      const animate = () => {
        context.clearRect(0, 0, width, height);
        orbitRotation += 0.00006;

        for (const star of stars) {
          star.angle += star.speed;
          star.twinkle += 0.018;

          const orbitalAngle = star.angle + orbitRotation;
          const x = centerX + Math.cos(orbitalAngle) * star.distance;
          const y = centerY + Math.sin(orbitalAngle) * star.distance * 0.86;

          const wrappedX = ((x % (width + 80)) + (width + 80)) % (width + 80) - 40;
          const wrappedY = ((y + star.drift * performance.now() * 0.0012) % (height + 80) + (height + 80)) %
            (height + 80) - 40;

          const alpha = star.alpha + Math.sin(star.twinkle) * 0.05;

          context.beginPath();
          context.fillStyle = `rgba(255, 255, 255, ${Math.max(0.06, alpha)})`;
          context.arc(wrappedX, wrappedY, star.size, 0, Math.PI * 2);
          context.fill();
        }

        requestAnimationFrame(animate);
      };

      resize();
      animate();
      window.addEventListener("resize", resize);
    }
  }
</script>
